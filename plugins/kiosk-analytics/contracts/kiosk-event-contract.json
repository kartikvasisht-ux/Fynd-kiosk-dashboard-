{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fynd Kiosk Analytics Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "event_name",
    "occurred_at",
    "session_id",
    "screen_name",
    "company_id",
    "application_id",
    "store_id",
    "source"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_name": {
      "type": "string",
      "enum": [
        "session_start",
        "session_end",
        "welcome_screen_view",
        "kiosk_app_bootstrap_started",
        "kiosk_config_loaded",
        "api_request_success",
        "api_request_failure",
        "store_context_loaded",
        "device_context_missing",
        "session_check_failed",
        "tap_get_started",
        "mobile_entry_view",
        "journey_form_schema_failed",
        "mobile_number_keypad_input",
        "mobile_number_submit",
        "otp_send_success",
        "otp_send_failure",
        "otp_resend",
        "otp_verify_success",
        "otp_verify_failure",
        "scan_home_view",
        "scan_start_clicked",
        "manual_barcode_open",
        "manual_barcode_submit",
        "manual_barcode_validation_error",
        "scan_attempt",
        "scan_success",
        "scan_failure",
        "item_resolved",
        "item_resolved_failure",
        "product_not_found",
        "oos_scan",
        "cart_add_started",
        "cart_add_success",
        "cart_add_failure",
        "cart_user_updated",
        "cart_view",
        "cart_quantity_changed",
        "cart_item_removed",
        "coupon_apply_clicked",
        "coupon_applied",
        "coupon_removed",
        "packaging_options_loaded",
        "voucher_options_loaded",
        "support_click",
        "gst_invoice_toggle",
        "checkout_start",
        "checkout_address_lookup",
        "payment_methods_view",
        "payment_options_loaded",
        "payment_options_failed",
        "payment_aggregator_key_loaded",
        "payment_method_selected",
        "payment_init",
        "payment_success",
        "payment_failure",
        "payment_timeout",
        "payment_cancelled",
        "payment_retry_clicked",
        "order_created",
        "order_creation_failed",
        "order_complete",
        "order_status_view",
        "journey_complete",
        "session_timeout",
        "app_crash"
      ]
    },
    "event_type": {
      "type": "string",
      "enum": [
        "session",
        "screen_view",
        "click",
        "input",
        "scan",
        "api",
        "cart",
        "checkout",
        "payment",
        "order",
        "system",
        "error"
      ]
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "enum": ["kiosk_frontend", "backend_webhook", "payment_gateway", "sentry", "mdm", "oms"] },
    "session_id": { "type": "string" },
    "screen_name": { "type": "string" },
    "action_name": { "type": "string" },
    "status": { "type": "string" },
    "source_url": { "type": "string" },
    "journey_stage": { "type": "string" },
    "company_id": { "type": "string" },
    "application_id": { "type": "string" },
    "store_id": { "type": "string" },
    "store_name": { "type": "string" },
    "device_session_id": { "type": "string" },
    "kiosk_id": { "type": "string" },
    "app_version": { "type": "string" },
    "user_id_hash": { "type": "string" },
    "mobile_hash": { "type": "string" },
    "cart_id_hash": { "type": "string" },
    "order_id_hash": { "type": "string" },
    "payment_session_id_hash": { "type": "string" },
    "payment_order_id_hash": { "type": "string" },
    "transaction_id_hash": { "type": "string" },
    "article": { "type": "string" },
    "barcode": { "type": "string" },
    "barcode_hash": { "type": "string" },
    "product_id": { "type": "string" },
    "brand_id": { "type": "string" },
    "line_item_id": { "type": "string" },
    "quantity": { "type": "number" },
    "amount": { "type": "number" },
    "currency": { "type": "string", "default": "INR" },
    "payment_mode": { "type": "string" },
    "aggregator_name": { "type": "string" },
    "failure_reason": { "type": "string" },
    "api_endpoint": { "type": "string" },
    "api_status": { "type": "integer" },
    "api_duration_ms": { "type": "number" },
    "context_missing": { "type": "string" }
  }
}
